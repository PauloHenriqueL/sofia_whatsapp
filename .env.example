# Sofia — .env.example
# Copie para .env e preencha os valores. NUNCA faça commit de .env

# ============================================================================
# WHATSAPP CLOUD API (Meta Business)
# ============================================================================
# Quando a conta Business estiver pronta, preencher estes valores
# Docs: https://developers.facebook.com/docs/whatsapp/cloud-api

# Token permanente do system user (não usar token temporário de 24h)
WHATSAPP_TOKEN=EAABa...

# ID do número de telefone na Cloud API
WHATSAPP_PHONE_NUMBER_ID=102...

# String secreta para validar webhook (definida por nós, qualquer valor seguro)
WHATSAPP_VERIFY_TOKEN=sofia-verify-token-super-secreto-123

# App secret (usado pra validar X-Hub-Signature-256)
WHATSAPP_APP_SECRET=abc123def456...

# Número de Thainá para receber alertas (formato: 5531999998888)
THAINA_WHATSAPP_NUMBER=5531999998888

# Nome do template aprovado na Meta
ALERT_TEMPLATE_NAME=alerta_thaina

# ============================================================================
# OPENAI
# ============================================================================
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o-mini

# ============================================================================
# BANCO DE DADOS (Postgres)
# ============================================================================
# Neon no desenvolvimento/produção
# Formato: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/sofia

# ============================================================================
# HAMILTON (API REST - Sistema clínico existente em Django)
# ============================================================================
# URL base do Hamilton
HAMILTON_API_URL=https://hamilton.allos.org.br

# Autenticação é JWT (SimpleJWT): a Sofia faz POST /authentication/token/ com
# usuário e senha de um usuário de serviço e usa o token Bearer retornado.
HAMILTON_USERNAME=sofia-bot
HAMILTON_PASSWORD=senha-do-usuario-de-servico

# (legado/opcional) Token estático, se um dia for usado.
HAMILTON_API_KEY=

# ============================================================================
# PAINEL WEB (Autenticação básica para MVP)
# ============================================================================
# Usuário para HTTP Basic Auth no painel (será Thainá)
PAINEL_USER=thaina

# Senha aleatória (gerar com: python -c "import secrets; print(secrets.token_urlsafe(32))")
PAINEL_PASSWORD=senha-super-secreta-aleatorio-123

# ============================================================================
# APLICAÇÃO
# ============================================================================
# development ou production
ENVIRONMENT=development

# Nivel de log: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Host e porta do FastAPI
HOST=0.0.0.0
PORT=5000

# Chave secreta da aplicação (gerar com: python -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=chave-secreta-super-segura-aleatorio-456

# ============================================================================
# RENDER (quando fazer deploy)
# ============================================================================
# Render fornecerá estes valores automaticamente:
# - DATABASE_URL (Postgres neon database)
# - Variáveis podem ser setadas no dashboard do Render
# Veja render.yaml para config do deploy
